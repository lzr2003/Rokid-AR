#!/usr/bin/env python
import os
import sys

env = SConscript("godot-cpp-4.5/SConstruct")

# 1. 包含源文件
sources = Glob("src/*.cpp")

# 2. 添加 Rokid 头文件搜索路径
env.Append(CPPPATH=["thirdparty/rokid/include"])

# 3. 针对 Android arm64 架构的特殊处理 (Rokid Station 环境)
if env["platform"] == "android" and env["arch"] == "arm64":
    # 告诉链接器 Rokid 动态库的路径
    env.Append(LIBPATH=["libs/arm64-v8a"])
    # 链接 libcxr.so (注意：这里写 cxr，不需要 lib 前缀和 .so 后缀)
    env.Append(LIBS=["libopenxr_loader"])

# 4. 生成动态库 (名称为 librokid_bridge)
library = env.SharedLibrary(
    "bin/libgdextension_rokid{}{}".format(env["suffix"], env["SHLIBSUFFIX"]),
    source=sources,
)
Default(library)