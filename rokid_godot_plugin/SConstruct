#!/usr/bin/env python
import os

env = SConscript("godot-cpp-4.5/SConstruct")

# 1. GDExtension 主库 — 包含所有 .cpp 除了 jni_bridge
gde_sources = Glob("src/*.cpp")
gde_sources = [s for s in gde_sources if "jni_bridge.cpp" not in str(s)]

env.Append(CPPPATH=["thirdparty/rokid/include"])

if env["platform"] == "android" and env["arch"] == "arm64":
    env.Append(LIBPATH=["libs/arm64-v8a"])
    env.Append(LIBS=["libopenxr_loader"])

gde_lib = env.SharedLibrary(
    "bin/libgdextension_rokid{}{}".format(env["suffix"], env["SHLIBSUFFIX"]),
    source=gde_sources,
)

# 2. JNI 桥接库 — 独立 .so，打包为 .aar 供 Godot .gdap 插件系统加载
if env["platform"] == "android":
    jni_env = env.Clone()
    jni_env.Append(CPPDEFINES=["ANDROID_ENABLED"])
    jni_lib = jni_env.SharedLibrary(
        "bin/librokid_jni{}{}".format(env["suffix"], env["SHLIBSUFFIX"]),
        source=["src/jni_bridge.cpp"],
    )
    # 打包为 android/plugins/rokid_jni_bridge.aar（Godot 4.3+ .gdap 格式）
    # 注意：SConstruct 在 rokid_godot_plugin/ 下，aar 要放到项目根目录的 android/plugins/
    import zipfile
    def package_jni_aar(target, source, env):
        # 以 SConstruct 所在目录为基准，定位到项目根目录
        sc_dir = env.Dir("#").abspath
        aar_dir = os.path.join(sc_dir, "..", "android", "plugins")
        aar_path = os.path.join(aar_dir, "rokid_jni_bridge.aar")
        os.makedirs(aar_dir, exist_ok=True)
        for s in source:
            so_path = str(s)
            with zipfile.ZipFile(aar_path, "w", zipfile.ZIP_DEFLATED) as zf:
                zf.write(so_path, "jni/arm64-v8a/" + os.path.basename(so_path))
    jni_env.AddPostAction(jni_lib, package_jni_aar)
    Default([gde_lib, jni_lib])
else:
    Default(gde_lib)