; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[android]

package/unique_name="com.rokid.xr.godot"
package/name="Rokid XR Godot"
xr_features_mode=2

[application]

config/name="Rokid XR Godot"
config/description="Rokid AR Glasses XR application with touchpad input and ray interaction."
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.5")
config/icon="res://icon.svg"

[autoload]

Station2IMU="*res://addons/rokid_xr/controller/station2_imu.gd"
TouchpadInput="*res://addons/rokid_xr/touchpad/touchpad_input.gd"
InteractableRegistry="*res://addons/rokid_xr/interaction/interactable_registry.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/transparent=true
window/per_pixel_transparency/enabled=true
window/size/handheld/orientation="landscape"

[input_devices]

pointing/emulate_mouse_from_touch=false
pointing/emulate_touch_from_mouse=false
sensors/enable_accelerometer=true
sensors/enable_gravity=true
sensors/enable_gyroscope=true
sensors/enable_magnetometer=true

[physics]

common/max_physics_steps_per_frame=4
3d/physics_engine="GodotPhysics3D"

[rendering]

renderer/rendering_method="mobile"
anti_aliasing/quality/msaa_3d=2
viewport/transparent_background=true

[xr]

openxr/enabled=true
openxr/reference_space="local"
openxr/environment_blend_mode="alpha_blend"
openxr/foveation_level=0
openxr/submit_depth_buffer=true
shaders/enabled=true
